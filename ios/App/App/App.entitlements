<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  App Group: shared container so the AudiobookshelfWidget extension (a separate process)
	  can read the current server URL + access token the app writes here. Self-service —
	  automatic signing provisions it, so device builds are unaffected.

	  CarPlay-audio (com.apple.developer.carplay-audio) was granted by Apple (2026-07) and is
	  enabled below. Device/TestFlight builds additionally need the entitlement in the provisioning
	  profile (handled in the fork's fastlane automation); otherwise signing fails.
	-->
	<key>com.apple.developer.carplay-audio</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.audiobookshelf.app</string>
	</array>
</dict>
</plist>
