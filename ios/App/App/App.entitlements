<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  App Group: shared container so the AudiobookshelfWidget extension (a separate process)
	  can read the current server URL + access token the app writes here. Self-service —
	  automatic signing provisions it, so device builds are unaffected.

	  NOTE: the CarPlay-audio entitlement is intentionally NOT in this (now wired) file, because
	  it needs Apple approval + a matching profile and would break device signing until granted.
	  Add `com.apple.developer.carplay-audio = true` here once Apple grants it.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.audiobookshelf.app</string>
	</array>
</dict>
</plist>
